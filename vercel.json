{
  "routes": [
    { "handle": "filesystem" },
    { "src": "/Operations_Analytics_Hub.html", "dest": "/Operations_Analytics_Hub.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/Operations_Analytics_Hub.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}